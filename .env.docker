# ============================================================
# architect-ai — Docker Development Environment
# Loaded by docker-compose.yml
# ============================================================
# Copy from .env.docker.example and fill in real values:
#   cp .env.docker.example .env.docker
# ============================================================

APP_NAME=ArchitGrid
APP_ENV=local
APP_KEY=base64:pDTNWl1jWwj3AC+nAE4jqEeuJvhDA8nq7NUgfuX/7OQ=
APP_DEBUG=true
APP_URL=http://localhost:8081

# ── MySQL (matches the db service in docker-compose.yml) ─────────────────────
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=architect_ai
DB_USERNAME=architect
DB_PASSWORD=architect_pass
DB_ROOT_PASSWORD=rootpass

# ── Cache / Session ──────────────────────────────────────────────────────────
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

# ── AI APIs (required for content generation) ─────────────────────────────────
OPENAI_API_KEY=
GEMINI_API_KEY=dismissed
MINIMAX_API_KEY=dismissed

# ── Cloud ────────────────────────────────────────────────────────────────────
CLOUDRISE_API_KEY=
CLOUDINARY_URL=

# ── IAM / Dev ────────────────────────────────────────────────────────────────
IAM_DEVELOPER_EMAIL=admin@dev.local
