# ========================================
# ArchitGrid - Production Environment Template
# ========================================
# For VPS deployment with Docker Compose (MySQL runs in the same stack).
# Copy to .env on your VPS and fill in real values:
#   cp .env.production.example .env
# This file is safe to commit — it contains NO secrets, only placeholders.

APP_NAME=ArchitGrid
APP_ENV=production
APP_KEY=base64:GENERATE_NEW_KEY_WITH_php_artisan_key:generate
APP_DEBUG=false
APP_URL=https://your-domain.com

# ========================================
# DATABASE (MySQL — runs as the "db" service in docker-compose.yml)
# ========================================
# DB_HOST=db resolves via Docker Compose internal networking.
# Do NOT expose port 3306 publicly on the VPS (remove or comment out
# the ports: mapping in docker-compose.yml for production).
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=architect_ai
DB_USERNAME=architect
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT_PASSWORD

# ========================================
# CACHE & SESSION
# ========================================
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

# For production with Redis (if using the architect-redis service):
# CACHE_DRIVER=redis
# SESSION_DRIVER=redis
# QUEUE_CONNECTION=redis
# REDIS_HOST=redis
# REDIS_PORT=6379

# ========================================
# MAIL (Production SMTP)
# ========================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=your-mailgun-username
MAIL_PASSWORD=your-mailgun-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@architgrid.com"
MAIL_FROM_NAME="${APP_NAME}"

# ========================================
# EXTERNAL SERVICES
# ========================================
# OpenAI
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

# MiniMax (primary AI)
MINIMAX_API_KEY=your-minimax-key

# Google Gemini (for Deep Research)
GEMINI_API_KEY=your-gemini-api-key

# Cloudinary (Media Storage)
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# ========================================
# SECURITY
# ========================================
IAM_DEVELOPER_EMAIL=your-admin@email.com

SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# ========================================
# LOGGING
# ========================================
LOG_CHANNEL=stack
LOG_LEVEL=error

# ========================================
# VITE (for asset building)
# ========================================
VITE_APP_NAME="${APP_NAME}"
