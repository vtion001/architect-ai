# ========================================
# ArchitGrid - Production Environment Template
# ========================================
# Copy these values to DigitalOcean App Platform Environment Variables
# This file is safe to commit - it contains NO secrets, only placeholders

APP_NAME=ArchitGrid
APP_ENV=production
APP_KEY=base64:GENERATE_NEW_KEY_WITH_php_artisan_key:generate
APP_DEBUG=false
APP_URL=https://your-app-domain.ondigitalocean.app

# ========================================
# DATABASE (DigitalOcean Managed MySQL)
# ========================================
# Get these values from: DigitalOcean Console → Databases → Your Cluster → Connection Details
DB_CONNECTION=mysql
DB_HOST=db-mysql-REGION-XXXXX-do-user-XXXXXXXX-0.b.db.ondigitalocean.com
DB_PORT=25060
DB_DATABASE=defaultdb
DB_USERNAME=doadmin
DB_PASSWORD=YOUR_DATABASE_PASSWORD

# Required for DigitalOcean Managed Databases (SSL)
MYSQL_ATTR_SSL_CA=/etc/ssl/certs/ca-certificates.crt

# ========================================
# CACHE & SESSION
# ========================================
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

# For production with Redis (optional):
# CACHE_DRIVER=redis
# SESSION_DRIVER=redis
# QUEUE_CONNECTION=redis
# REDIS_HOST=your-redis-host.ondigitalocean.com
# REDIS_PASSWORD=your-redis-password
# REDIS_PORT=25061

# ========================================
# MAIL (Production SMTP)
# ========================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=your-mailgun-username
MAIL_PASSWORD=your-mailgun-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@architgrid.com"
MAIL_FROM_NAME="${APP_NAME}"

# ========================================
# EXTERNAL SERVICES
# ========================================
# OpenAI
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

# Google Gemini (for Deep Research)
GEMINI_API_KEY=your-gemini-api-key

# Cloudinary (Media Storage)
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# ========================================
# SECURITY
# ========================================
# Developer email for super-admin access
IAM_DEVELOPER_EMAIL=your-admin@email.com

# Session & Cookie Security
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# ========================================
# LOGGING
# ========================================
LOG_CHANNEL=stack
LOG_LEVEL=error

# ========================================
# VITE (for asset building)
# ========================================
VITE_APP_NAME="${APP_NAME}"
