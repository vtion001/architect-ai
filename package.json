        "axios": "^1.7.4",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^1.0",
        "lighthouse": "^13.1.0",
        "postcss": "^8.4.47",
        "tailwindcss": "^3.4.13",
        "terser": "^5.46.0",
        "typescript": "^6.0.2",
        "vite": "^5.0.0"
    },
    "dependencies": {
        "@stoplight/elements": "^9.0.15",
        "alpinejs": "^3.15.4",
        "chart.js": "^4.5.1",
        "lucide": "^0.562.0"
