{
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "type-check": "tsc --noEmit",
        "test:e2e": "playwright test",
        "lh": "lighthouse http://localhost:8081/dashboard --output=html --output-path=./reports/lh-dashboard.html --chrome-flags=\"--headless\" --preset=desktop",
        "lh:mobile": "lighthouse http://localhost:8081/dashboard --output=html --output-path=./reports/lh-dashboard-mobile.html --chrome-flags=\"--headless\" --preset=mobile",
        "lh:ci": "lhci autorun",
        "lh:server": "npx http-server ./reports -p 8082",
        "analyze": "vite build --mode analyze"
    },
    "devDependencies": {
        "@playwright/test": "^1.59.1",
        "@types/alpinejs": "^3.13.11",
        "@types/node": "^25.6.0",
