{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "strict": true,
        "noEmit": true,
        "skipLibCheck": true,
        "allowJs": true,
        "checkJs": false,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "ignoreDeprecations": "6.0",
        "baseUrl": ".",
        "paths": {
            "@/*": ["resources/js/*"]
        },
        "types": ["node"]
    },
    "include": [
        "resources/js/**/*",
        "vite.config.js"
    ],
    "exclude": [
        "node_modules",
        "public",
        "vendor"
    ]
}
